{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@pkg/*": ["../pkg/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}