# ─────────────────────────────────────────────
# Docker 构建时排除的文件
# 减小上下文、避免敏感信息进镜像
# ─────────────────────────────────────────────

# 依赖（镜像内重装）
node_modules/

# 运行时数据（用卷挂载）
data/
*.db
*.db-shm
*.db-wal

# 敏感配置（含 API key）
.env
.env.local
.env.*.local
config.yaml

# 日志
*.log
logs/

# 源码控制
.git/
.gitignore
.github/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# 文档 / 截图
*.md
!README.md
docs/
screenshots/

# 测试脚本（运行时不需要，typecheck 在 build 阶段用）
scripts/

# CI/CD（镜像内不需要）
.claude/
.cursorrules
AGENTS.md
