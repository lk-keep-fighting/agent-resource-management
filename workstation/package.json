{
  "name": "agent-workstation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --env-file=.env --watch src/server.ts",
    "start": "bun run --env-file=.env src/server.ts",
    "migrate": "bun run --env-file=.env src/db/migrate.ts",
    "mock-arm": "bun run scripts/mock-arm.ts",
    "typecheck": "bun --bun tsc --noEmit"
  },
  "dependencies": {
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "9",
    "@earendil-works/pi-agent-core": "^0.79.9",
    "@earendil-works/pi-ai": "^0.79.9",
    "@earendil-works/pi-coding-agent": "^0.79.9",
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0",
    "typebox": "^1.1.0",
    "uuid": "^11.0.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/uuid": "^10.0.0",
    "puppeteer-core": "^25.1.0",
    "typescript": "^5.4.0"
  },
  "trustedDependencies": [
    "@google/genai",
    "protobufjs"
  ]
}