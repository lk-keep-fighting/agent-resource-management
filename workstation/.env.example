# Agent Workstation 环境变量示例
# 复制为 .env 后填入真实值，docker compose 会自动加载

# ─── 必填 ───
# 智谱 GLM Coding Plan API key
WS_LLM_API_KEY=your-glm-api-key-here

# ARM Backend 地址
# 本机开发：host.docker.internal:3000（macOS/Windows）
# 同网络部署：http://arm:3000
# 公网部署：https://arm.example.com
WS_ARM_BASE_URL=http://host.docker.internal:3000

# ─── 可选（有默认值） ───
WS_LLM_PROVIDER=openai
WS_LLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
WS_LLM_MODEL=glm-4.5

# ARM API Key（如有，不填也可用 SSO）
# WS_ARM_API_KEY=

# SSO 服务 URL（影响 callback 跳回）
# NEXT_PUBLIC_SSO_URL=http://sso.agent-platform.dev.aimstek.cn

# Workstation 公网可访问 URL（用于 SSO 回调地址拼接）
# 例：https://ws.example.com
# 不设则从请求头自动检测（X-Forwarded-Proto + Host），反代场景下足够
# 本地开发：默认 http://localhost:4000
# WS_PUBLIC_ORIGIN=https://ws.example.com
