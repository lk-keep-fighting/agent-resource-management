generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id
  name       String
  email      String   @unique
  apiKeyHash String   @unique @map("api_key_hash")
  createdAt  DateTime @default(now()) @map("created_at")

  skills Skill[]
  agents Agent[]

  @@index([email], name: "idx_email")
  @@index([apiKeyHash], name: "idx_api_key_hash")
  @@map("users")
}

model Skill {
  id            String   @id
  name          String   @unique
  description   String   @db.VarChar(1024)
  license       String?
  compatibility String?
  metadata      Json?
  allowedTools  Json?    @map("allowed_tools")
  fileSize      BigInt   @map("file_size")
  fileHash      String   @map("file_hash")
  content       String?  @db.Text
  publishedAt   DateTime @map("published_at")
  publishedBy   String   @map("published_by")
  updatedAt     DateTime @updatedAt @map("updated_at")
  downloadCount Int      @default(0) @map("download_count")
  status        SkillStatus @default(active)

  publisher User @relation(fields: [publishedBy], references: [id], onDelete: Cascade)
  skillTags SkillTag[]
  agentSkills AgentSkill[]

  @@index([name], name: "idx_name")
  @@index([status], name: "idx_status")
  @@index([publishedBy], name: "idx_published_by")
  @@index([publishedAt], name: "idx_published_at")
  @@map("skills")
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  skillTags SkillTag[]

  @@map("tags")
}

model SkillTag {
  skillId String
  tagId   String

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([skillId, tagId])
  @@map("skill_tags")
}

enum SkillStatus {
  active
  draft
  deleted
}

model Agent {
  id          String   @id @default(uuid())
  name        String   @unique
  description String   @db.VarChar(512)
  prompt      String   @db.Text
  avatar      String?
  status      AgentStatus @default(active)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   String   @map("created_by")

  creator         User            @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  agentSkills    AgentSkill[]
  agentKnowledges AgentKnowledge[]

  @@index([name], name: "idx_agent_name")
  @@index([createdBy], name: "idx_agent_created_by")
  @@map("agents")
}

enum AgentStatus {
  active
  draft
}

model AgentSkill {
  agentId   String
  skillId   String
  config    Json?

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([agentId, skillId])
  @@map("agent_skills")
}

model AgentKnowledge {
  agentId         String
  knowledgeId     String   @map("knowledge_id")
  retrievalConfig Json?    @map("retrieval_config")
  createdAt       DateTime @default(now()) @map("created_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@id([agentId, knowledgeId])
  @@map("agent_knowledges")
}
