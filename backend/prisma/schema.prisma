generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  ssoUserId     String   @unique @map("sso_user_id")
  feishuUnionId String?  @unique @map("feishu_union_id")
  name          String?
  email         String?  @unique
  passwordHash  String?  @map("password_hash")
  apiKeyHash       String?  @unique @map("api_key_hash")
  encryptedApiKey  String?  @map("encrypted_api_key")
  role          String   @default("USER")
  avatarUrl     String?  @map("avatar_url")
  createdAt     DateTime @default(now()) @map("created_at")

  skills Skill[]
  agents Agent[]
  knowledges Knowledge[]

  @@index([email], name: "idx_email")
  @@index([apiKeyHash], name: "idx_api_key_hash")
  @@index([ssoUserId], name: "idx_sso_user_id")
  @@map("users")
}

model Skill {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String   @db.VarChar(1024)
  license       String?
  compatibility String?
  metadata      Json?
  allowedTools  Json?    @map("allowed_tools")
  fileSize      BigInt   @map("file_size")
  fileHash      String   @map("file_hash")
  content       String?  @db.Text
  publishedAt   DateTime @map("published_at")
  publishedBy   String   @map("published_by")
  updatedAt     DateTime @updatedAt @map("updated_at")
  downloadCount Int      @default(0) @map("download_count")
  status        SkillStatus @default(active)

  publisher User @relation(fields: [publishedBy], references: [id], onDelete: Cascade)
  skillTags SkillTag[]
  agentSkillBindings AgentSkillBinding[]
  feedbacks SkillFeedback[]

  @@index([name], name: "idx_name")
  @@index([status], name: "idx_status")
  @@index([publishedBy], name: "idx_published_by")
  @@index([publishedAt], name: "idx_published_at")
  @@map("skills")
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  skillTags     SkillTag[]
  knowledgeTags KnowledgeTag[]

  @@map("tags")
}

model SkillTag {
  skillId String
  tagId   String

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([skillId, tagId])
  @@map("skill_tags")
}

enum SkillStatus {
  active
  draft
  deleted
}

model Agent {
  id          String   @id @default(uuid())
  name        String   @unique
  description String   @db.VarChar(512)
  prompt      String   @db.Text
  avatar      String?
  version     String   @default("1.0.0") @map("version")
  status      AgentStatus @default(active)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   String   @map("created_by")

  creator              User                   @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  skillBindings        AgentSkillBinding[]
  knowledgeBindings    AgentKnowledgeBinding[]
  feedbacks            AgentFeedback[]

  @@index([name], name: "idx_agent_name")
  @@index([createdBy], name: "idx_agent_created_by")
  @@index([version], name: "idx_agent_version")
  @@map("agents")
}

model AgentFeedback {
  id          String   @id @default(uuid())
  agentId     String   @map("agent_id")
  agentVersion String? @map("agent_version")
  rating      Int?
  isHelpful   Boolean? @map("is_helpful")
  comment     String?  @db.Text
  tagsJson    Json?    @map("tags_json")
  source      String?  @map("source")
  externalRunId String? @unique @map("external_run_id")
  feedbackTo  String?  @map("feedback_to")
  createdAt   DateTime @default(now()) @map("created_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId], name: "idx_feedback_agent")
  @@index([createdAt], name: "idx_feedback_created")
  @@index([feedbackTo], name: "idx_feedback_to")
  @@map("agent_feedbacks")
}

enum AgentStatus {
  active
  draft
}

model AgentSkillBinding {
  id        String   @id @default(uuid())
  agentId   String
  skillId   String
  version   String
  config    Json?
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([agentId], name: "idx_skill_binding_agent")
  @@index([skillId], name: "idx_skill_binding_skill")
  @@unique([agentId, skillId, version], name: "uq_agent_skill_version")
  @@map("agent_skill_bindings")
}

model AgentKnowledgeBinding {
  id              String    @id @default(uuid())
  agentId         String
  knowledgeId     String    @map("knowledge_id")
  version         String
  retrievalConfig Json?     @map("retrieval_config")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  agent     Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  knowledge Knowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)

  @@index([agentId], name: "idx_knowledge_binding_agent")
  @@index([knowledgeId], name: "idx_knowledge_binding_knowledge")
  @@unique([agentId, knowledgeId, version], name: "uq_agent_knowledge_version")
  @@map("agent_knowledge_bindings")
}

model Knowledge {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?  @db.VarChar(1024)
  content     String?  @db.LongText
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   String   @map("created_by")

  creator           User                     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  knowledgeTags     KnowledgeTag[]
  knowledgeBindings AgentKnowledgeBinding[]
  feedbacks         KnowledgeFeedback[]

  @@index([name], name: "idx_knowledge_name")
  @@map("knowledges")
}

model SkillFeedback {
  id              String   @id @default(uuid())
  skillId         String   @map("skill_id")
  skillVersion    String?  @map("skill_version")
  rating          Int?
  isHelpful       Boolean? @map("is_helpful")
  comment         String?  @db.Text
  tagsJson        Json?    @map("tags_json")
  source          String?  @map("source")
  externalRunId   String?  @unique @map("external_run_id")
  feedbackTo      String?  @map("feedback_to")  // 反馈目标 user id（被通知的人）
  createdAt       DateTime @default(now()) @map("created_at")

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([skillId], name: "idx_skill_feedback_skill")
  @@index([createdAt], name: "idx_skill_feedback_created")
  @@index([feedbackTo], name: "idx_skill_feedback_to")
  @@map("skill_feedbacks")
}

model KnowledgeFeedback {
  id              String   @id @default(uuid())
  knowledgeId     String   @map("knowledge_id")
  knowledgeVersion String? @map("knowledge_version")
  rating          Int?
  isHelpful       Boolean? @map("is_helpful")
  comment         String?  @db.Text
  tagsJson        Json?    @map("tags_json")
  source          String?  @map("source")
  externalRunId   String?  @unique @map("external_run_id")
  feedbackTo      String?  @map("feedback_to")
  createdAt       DateTime @default(now()) @map("created_at")

  knowledge Knowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)

  @@index([knowledgeId], name: "idx_knowledge_feedback_knowledge")
  @@index([createdAt], name: "idx_knowledge_feedback_created")
  @@index([feedbackTo], name: "idx_knowledge_feedback_to")
  @@map("knowledge_feedbacks")
}

model Notification {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")          // 接收人
  type        String                              // agent_feedback | skill_feedback | knowledge_feedback
  refId       String   @map("ref_id")           // 关联资源 id（agent/skill/knowledge）
  refName     String?  @map("ref_name")
  title       String
  body        String?  @db.Text
  metaJson    Json?    @map("meta_json")        // rating / comment 等
  isRead      Boolean  @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId, isRead], name: "idx_notification_user_unread")
  @@index([userId, createdAt], name: "idx_notification_user_time")
  @@map("notifications")
}

model KnowledgeTag {
  knowledgeId String
  tagId       String

  knowledge Knowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  tag       Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([knowledgeId, tagId])
  @@map("knowledge_tags")
}

model ExternalKnowledgeSource {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?  @db.VarChar(512)
  status      String   @default("active")
  
  endpoint    String   @db.VarChar(1024)
  authType    String   @default("none")
  authHeader  String?  @map("auth_header")
  authValue   String?  @map("auth_value")
  
  idField     String   @default("id")
  titleField  String   @default("title")
  contentField String  @default("content")
  descField   String?  @map("desc_field")
  updatedField String? @map("updated_field")
  contentType String   @default("markdown")
  
  method      String   @default("GET")
  headers     Json?
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   String   @map("created_by")

  @@index([status], name: "idx_external_source_status")
  @@index([createdBy], name: "idx_external_source_created_by")
  @@map("external_knowledge_sources")
}
