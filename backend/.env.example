# ARM backend environment template
# Copy this file to .env and fill in the values below.

# ─────────── Database ───────────
# MySQL connection string for Prisma
DATABASE_URL=mysql://user:password@host:3306/arm

# ─────────── ARM server ───────────
# Public origin used for OAuth callback redirects (defaults to request origin)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ─────────── Feishu OAuth (direct, no IdP middleware) ───────────
# Get these from https://open.feishu.cn/app → your app → Credentials
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here
# Must be registered in the Feishu app's "Security settings → Redirect URLs"
FEISHU_REDIRECT_URI=http://localhost:3001/api/auth/callback

# ─────────── OpenAI-compatible LLM (for skills/agents) ───────────
OPENAI_API_KEY=
OPENAI_BASE_URL=